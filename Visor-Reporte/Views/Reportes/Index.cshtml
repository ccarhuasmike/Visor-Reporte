
@using ReportViewerForMvc

@{
    Layout = null;
}

<body style="overflow:hidden;text-align:center;">
    @if (ViewBag.ReportViewer != null)
    {
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer, new { @width = "100%", @height = "100%" })
    }
</body>

